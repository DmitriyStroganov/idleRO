{
  "name": "idle-ro",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Idle auto-battler inspired by Ragnarok Online (pre-Renewal). Single-player PWA with configurable AI behavior.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^0.20.5",
    "vitest": "^2.1.4"
  }
}
